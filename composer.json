{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "redot/core",
    "type": "library",
    "license": "proprietary",
    "description": "Core package for Redot Dashboard that has all the packages and helpers for the dashboard.",
    "keywords": [
        "redot",
        "dashboard",
        "laravel"
    ],
    "require": {
        "php": "^8.3",
        "giggsey/libphonenumber-for-php": "^9.0",
        "intervention/image-laravel": "^4.0",
        "laravel/framework": "^13.0",
        "laravel/sanctum": "^4.3",
        "livewire/livewire": "^4.2",
        "spatie/laravel-image-optimizer": "^1.8",
        "spatie/laravel-permission": "^7.3"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.8",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.2",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Redot\\": "src/",
            "Redot\\Auth\\": "src/packages/auth/src",
            "Redot\\Sidebar\\": "src/packages/sidebar/src",
            "Redot\\Toastify\\": "src/packages/toastify/src",
            "Redot\\Datatables\\": "src/packages/datatables/src",
            "Redot\\LangExtractor\\": "src/packages/lang-extractor/src"
        },
        "files": [
            "src/packages/toastify/src/helpers.php",
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": [
            "@php vendor/bin/pint"
        ],
        "test": [
            "@php vendor/bin/pest"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Redot\\RedotServiceProvider"
            ],
            "dont-discover": []
        }
    },
    "config": {
        "platform": {
            "php": "8.3"
        },
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
